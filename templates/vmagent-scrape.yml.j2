global:
  scrape_interval: {{ vmagent_scrape_interval }}
  evaluation_interval: {{ vmagent_scrape_interval }}
  external_labels:
    datacenter: vnpt-cloud
    environment: production

# =============================================================================
# Scrape config tự generate từ thư mục targets/
# Để thêm/xóa client: chỉ cần sửa file trong targets/ rồi chạy:
#   ./run.sh reconfig --tags targets
# vmagent tự reload, không restart
# =============================================================================

scrape_configs:

# ==============================================================================
# NODE EXPORTER — đọc từ targets/node_exporter.yml
# ==============================================================================
{% set ne_targets = lookup('file', playbook_dir + '/../targets/node_exporter.yml') | from_yaml %}
  - job_name: node_exporter
    static_configs:
{% for group in ne_targets.groups %}
{% if group.hosts %}
{% for h in group.hosts %}
{% set host_ip = h.host %}
{% set host_port = h.port | default(node_exporter_port) %}
{% set merged_labels = group.labels | combine(h['labels'] | default({})) %}
      - targets:
          - "{{ host_ip }}:{{ host_port }}"
        labels:
          instance: "{{ host_ip }}"
{% for k, v in merged_labels.items() %}
          {{ k }}: "{{ v }}"
{% endfor %}
{% endfor %}
{% endif %}
{% endfor %}
    relabel_configs:
      - source_labels: [instance]
        target_label: hostname

# ==============================================================================
# CEPH — đọc từ targets/ceph.yml
# ==============================================================================
{% set ceph_targets = lookup('file', playbook_dir + '/../targets/ceph.yml') | from_yaml %}
  - job_name: ceph
    static_configs:
{% for group in ceph_targets.groups %}
{% if group.hosts %}
{% for h in group.hosts %}
{% set merged_labels = group.labels | combine(h['labels'] | default({})) %}
      - targets:
          - "{{ h.host }}:{{ h.port | default(9283) }}"
        labels:
          instance: "{{ h.host }}"
{% for k, v in merged_labels.items() %}
          {{ k }}: "{{ v }}"
{% endfor %}
{% endfor %}
{% endif %}
{% endfor %}

