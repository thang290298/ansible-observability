# ==============================================================================
# SELF-MONITOR — tự generate từ inventory (không thay đổi)
# ==============================================================================
  - job_name: victoriametrics
    static_configs:
{% for host in groups['monitoring'] %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] }}:{{ vmstorage_port }}"
          - "{{ hostvars[host]['ansible_host'] }}:{{ vminsert_port }}"
          - "{{ hostvars[host]['ansible_host'] }}:{{ vmselect_port }}"
        labels:
          instance: "{{ host }}"
          role: monitoring
{% endfor %}

  - job_name: haproxy
    static_configs:
{% for host in groups['monitoring'] %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] }}:{{ haproxy_stats_port }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  - job_name: alertmanager
    static_configs:
{% for host in groups['monitoring'][:2] %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] }}:{{ alertmanager_port }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  - job_name: grafana
    static_configs:
{% for host in groups['monitoring'] %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] }}:{{ grafana_port }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  # ==========================================================================
  # LOKI (auto-generate từ monitoring_loki group)
  # ==========================================================================
  - job_name: loki
    static_configs:
{% for host in groups['monitoring_loki'] %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] }}:{{ loki_port }}"
        labels:
          instance: "{{ host }}"
          component: loki
{% endfor %}

  # ==========================================================================
  # PROMTAIL (auto-generate từ promtail_nodes group)
  # ==========================================================================
  - job_name: promtail
    static_configs:
{% for host in groups['promtail_nodes'] %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] }}:{{ promtail_port }}"
        labels:
          instance: "{{ host }}"
          site: "{{ hostvars[host]['site'] | default('unknown') }}"
          role: "{{ hostvars[host]['role'] | default('server') }}"
{% endfor %}
