---
# inventory/group_vars/vault.yml.example
# Copy file này thành vault.yml rồi điền giá trị thật, sau đó encrypt:
#   ansible-vault encrypt inventory/group_vars/vault.yml
#
# Để decrypt chỉnh sửa:
#   ansible-vault edit inventory/group_vars/vault.yml

vault_telegram_bot_token: ""
vault_telegram_chat_id: ""
vault_telegram_critical_chat_id: ""

vault_grafana_admin_password: ""
vault_grafana_db_password: ""
vault_postgres_password: ""

vault_vrrp_auth_pass: ""
vault_haproxy_stats_password: ""

vault_gitea_db_password: ""
vault_ansible_webhook_secret: ""
vault_gitea_secret_key: ""             # Gitea SECRET_KEY (riêng với webhook secret)

vault_minio_root_user: ""
vault_minio_root_password: ""
