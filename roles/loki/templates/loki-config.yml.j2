auth_enabled: false

server:
  http_listen_port: {{ loki_port }}
  grpc_listen_port: {{ loki_grpc_port }}
  log_level: warn

common:
  instance_addr: {{ ansible_host }}
  path_prefix: /loki
  replication_factor: 2
  ring:
    kvstore:
      store: memberlist

memberlist:
  join_members:
{% for host in groups['monitoring_loki'] %}
    - {{ hostvars[host]['ansible_host'] }}:{{ loki_memberlist_port }}
{% endfor %}
  bind_addr: ['0.0.0.0']
  bind_port: {{ loki_memberlist_port }}
  advertise_addr: {{ ansible_host }}
  advertise_port: {{ loki_memberlist_port }}
  dead_node_reclaim_time: 30s

{% if s3_enabled | default(false) %}
storage_config:
  aws:
    endpoint: {{ s3_endpoint }}
    access_key_id: {{ s3_access_key }}
    secret_access_key: {{ s3_secret_key }}
    region: {{ s3_region }}
    bucketnames: {{ s3_loki_bucket }}
    s3forcepathstyle: true
    insecure: false
  filesystem:
    directory: /loki/chunks

schema_config:
  configs:
    - from: 2024-01-01
      store: tsdb
      object_store: s3
      schema: v13
      index:
        prefix: loki_index_
        period: 24h

{% else %}
storage_config:
  filesystem:
    directory: /loki/chunks

schema_config:
  configs:
    - from: 2024-01-01
      store: tsdb
      object_store: filesystem
      schema: v13
      index:
        prefix: loki_index_
        period: 24h

{% endif %}

ingester:
  wal:
    enabled: true
    dir: /loki/wal
  lifecycler:
    ring:
      kvstore:
        store: memberlist
      replication_factor: 2
  chunk_idle_period: 30m
  chunk_block_size: 262144
  chunk_retain_period: 1m

querier:
  max_concurrent: 10

query_range:
  results_cache:
    cache:
      embedded_cache:
        enabled: true
        max_size_mb: 100

ruler:
  storage:
    type: local
    local:
      directory: /loki/rules
  rule_path: /loki/rules-temp
  ring:
    kvstore:
      store: memberlist

compactor:
  working_directory: /loki/compactor
  compaction_interval: 10m
  retention_enabled: true
  retention_delete_delay: 2h
  retention_delete_worker_count: 150
  delete_request_store: {% if s3_enabled | default(false) %}s3{% else %}filesystem{% endif %}

limits_config:
  retention_period: {{ loki_retention_period | default('30d') }}
  ingestion_rate_mb: 32
  ingestion_burst_size_mb: 64
  max_query_lookback: {{ loki_retention_period | default('30d') }}
  split_queries_by_interval: 24h
  max_streams_per_user: 100000
  max_global_streams_per_user: 100000
  reject_old_samples: false
  reject_old_samples_max_age: 168h
  creation_grace_period: 24h
analytics:
  reporting_enabled: false
