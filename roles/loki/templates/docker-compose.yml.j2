
# =============================================================================
# Loki — Log aggregation
# Chạy trên {{ groups['monitoring_loki'] | length }} nodes
# Nodes: {{ groups['monitoring_loki'] | map('extract', hostvars, 'ansible_host') | join(', ') }}
# =============================================================================

services:
  loki:
    image: grafana/loki:{{ loki_version }}
    container_name: loki
    restart: unless-stopped
    command:
      - "-config.file=/etc/loki/config.yml"
      - "-config.expand-env=true"
    volumes:
      - ./config.yml:/etc/loki/config.yml:ro
      - {{ loki_data_path }}:/loki          # mount toàn bộ: WAL + cache đều nằm đây
    ports:
      - "{{ loki_internal_port | default(loki_port) }}:{{ loki_port }}"
      - "{{ loki_grpc_port }}:{{ loki_grpc_port }}"
      - "{{ loki_memberlist_port }}:{{ loki_memberlist_port }}"
    mem_limit: "{{ loki_mem_limit | default('2g') }}"
    cpus: "{{ loki_cpu_limit | default('1.5') }}"
    labels:
      monitoring: "true"
      component: "loki"
    logging:
      driver: "json-file"
      options:
        max-size: "100m"
        max-file: "3"
