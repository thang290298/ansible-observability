vrrp_script chk_haproxy {
    script "killall -0 haproxy"
    interval 2
    weight 2
    fall 3
    rise 2
}

vrrp_instance VI_MONITORING {
    # MASTER chỉ ở node đầu tiên trong group, còn lại là BACKUP
    state {{ 'MASTER' if groups['monitoring_lb'].index(inventory_hostname) == 0 else 'BACKUP' }}
    interface {{ vip_interface }}
    virtual_router_id {{ vrrp_router_id }}
    priority {{ keepalived_base_priority - (groups['monitoring_lb'].index(inventory_hostname) * keepalived_priority_step) }}
    advert_int 1

    # nopreempt chỉ áp dụng cho BACKUP — MASTER không cần
    # Mục đích: sau khi MASTER recover, VIP KHÔNG tự chuyển về MASTER
    # → tránh flapping, tăng ổn định cho production
    # Bỏ comment dòng dưới nếu muốn MASTER tự quay về sau recover:
{% if groups['monitoring_lb'].index(inventory_hostname) != 0 %}
    nopreempt
{% endif %}

    authentication {
        auth_type PASS
        auth_pass {{ vrrp_auth_pass }}
    }

    virtual_ipaddress {
        {{ vip_address }}/24
    }

    track_script {
        chk_haproxy
    }

    notify_master "/etc/keepalived/notify.sh MASTER {{ vip_address }}"
    notify_backup "/etc/keepalived/notify.sh BACKUP {{ vip_address }}"
    notify_fault  "/etc/keepalived/notify.sh FAULT {{ vip_address }}"
}
