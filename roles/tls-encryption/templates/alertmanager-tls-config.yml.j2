# AlertManager TLS Configuration

global:
  resolve_timeout: 5m

api:
  # Require TLS for API endpoints
  tls_server_config:
    cert_file: {{ services_tls.alertmanager.cert_file }}
    key_file: {{ services_tls.alertmanager.key_file }}
    min_version: {{ tls_min_version }}
    max_version: {{ tls_max_version }}

# Client TLS for alerting backends
clients:
  - scheme: https
    tls_config:
      ca_file: ca.crt
      insecure_skip_verify: false
