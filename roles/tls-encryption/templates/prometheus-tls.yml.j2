# Prometheus TLS Configuration
# Web server TLS settings

global:
  external_labels:
    __scheme__: 'https'

web:
  tls_server_config:
    cert_file: prometheus.crt
    key_file: prometheus.key
    min_version: '{{ tls_min_version }}'
    max_version: '{{ tls_max_version }}'
    cipher_suites:
      {% for cipher in tls_cipher_suites %}
      - '{{ cipher }}'
      {% endfor %}

http_sd_configs:
  scheme: https
  tls_config:
    ca_file: ca.crt
    insecure_skip_verify: false
