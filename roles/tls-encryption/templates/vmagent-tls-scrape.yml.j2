# vmagent TLS Scrape Configuration
# Enable TLS for scrape targets

global:
  scrape_timeout: 10s
  scrape_interval: 15s

# TLS for scraping other targets
scrape_configs:
  - job_name: 'prometheus'
    scheme: https
    tls_config:
      ca_file: ca.crt
      cert_file: {{ services_tls.vmagent.cert_file }}
      key_file: {{ services_tls.vmagent.key_file }}
      insecure_skip_verify: false
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    scheme: https
    tls_config:
      ca_file: ca.crt
      insecure_skip_verify: false
    static_configs:
      - targets: ['localhost:9100']
