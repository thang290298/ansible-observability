global
    log /dev/log local0
    maxconn 50000
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    tune.ssl.default-dh-param 2048
    # Tăng buffer cho vminsert batch writes (default 16384 không đủ)
    tune.bufsize 32768
    tune.maxrewrite 8192

defaults
    mode    http
    log     global
    option  httplog
    option  forwardfor
    option  http-server-close
    option  redispatch
    timeout connect  5s
    timeout client   60s
    timeout server   60s
    retries 3
    option  dontlog-normal

# =============================================================================
# STATS PAGE
# =============================================================================
frontend stats
    bind *:{{ haproxy_stats_port }}
    stats enable
    stats uri /stats
    stats refresh 10s
    stats show-legends
    stats show-node
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats admin if LOCALHOST

# =============================================================================
# GRAFANA — session persistence qua cookie
# Group: monitoring_grafana ({{ groups['monitoring_grafana'] | length }} nodes)
# =============================================================================
frontend grafana_front
    bind *:80
    default_backend grafana_back

backend grafana_back
    balance leastconn
    cookie GRAFANA_NODE insert indirect nocache
    option httpchk GET /api/health
    http-check expect status 200
{% for host in groups['monitoring_grafana'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:{{ grafana_port }} \
        check inter 2s fall 3 rise 2 cookie s{{ loop.index }}
{% endfor %}

# =============================================================================
# VMINSERT — round robin write
# Group: monitoring_query ({{ groups['monitoring_query'] | length }} nodes)
# =============================================================================
frontend vminsert_front
