services:
  prometheus:
    image: prom/prometheus:latest
    cpus: "{{ container_limits.prometheus.cpu_limit }}"
    mem_limit: {{ container_limits.prometheus.memory_limit }}
    mem_reservation: 512m
    memswap_limit: {{ container_limits.prometheus.memory_swap }}
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:9090/-/healthy"]
      interval: 30s
      timeout: 10s
      retries: 3

  grafana:
    image: grafana/grafana:latest
    cpus: "{{ container_limits.grafana.cpu_limit }}"
    mem_limit: {{ container_limits.grafana.memory_limit }}
    mem_reservation: 256m
    memswap_limit: {{ container_limits.grafana.memory_swap }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  loki:
    image: grafana/loki:latest
    cpus: "{{ container_limits.loki.cpu_limit }}"
    mem_limit: {{ container_limits.loki.memory_limit }}
    mem_reservation: 512m
    memswap_limit: {{ container_limits.loki.memory_swap }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3100/ready"]
      interval: 30s
      timeout: 10s
      retries: 3

  vmstorage:
    image: victoriametrics/vmstorage:latest
    cpus: "{{ container_limits.vmstorage.cpu_limit }}"
    mem_limit: {{ container_limits.vmstorage.memory_limit }}
    mem_reservation: 1g
    memswap_limit: {{ container_limits.vmstorage.memory_swap }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8482/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  vmselect:
    image: victoriametrics/vmselect:latest
    cpus: "{{ container_limits.vmselect.cpu_limit }}"
    mem_limit: {{ container_limits.vmselect.memory_limit }}
    mem_reservation: 256m
    memswap_limit: {{ container_limits.vmselect.memory_swap }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8481/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  vminsert:
    image: victoriametrics/vminsert:latest
    cpus: "{{ container_limits.vminsert.cpu_limit }}"
    mem_limit: {{ container_limits.vminsert.memory_limit }}
    mem_reservation: 256m
    memswap_limit: {{ container_limits.vminsert.memory_swap }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8480/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  vmagent:
    image: victoriametrics/vmagent:latest
    cpus: "{{ container_limits.vmagent.cpu_limit }}"
    mem_limit: {{ container_limits.vmagent.memory_limit }}
    mem_reservation: 256m
    memswap_limit: {{ container_limits.vmagent.memory_swap }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8429/health"]
      interval: 30s
      timeout: 10s
      retries: 3
