# roles/telegraf/templates/telegraf.conf.j2
# Base configuration — Agent settings + VictoriaMetrics output
# Generated by Ansible — DO NOT EDIT MANUALLY

[agent]
  interval = "{{ telegraf_interval }}"
  round_interval = true
  metric_batch_size = 1000
  metric_buffer_limit = 10000
  collection_jitter = "2s"
  flush_interval = "{{ telegraf_flush_interval }}"
  flush_jitter = "2s"
  precision = "0s"
  hostname = "{{ telegraf_hostname }}"
  omit_hostname = false
  logfile = "{{ telegraf_log_file }}"
  logfile_rotation_max_size = "10MB"
  logfile_rotation_max_archives = 3

# =============================================================================
# OUTPUT: VictoriaMetrics via InfluxDB v1 HTTP write
# =============================================================================
[[outputs.influxdb]]
  urls = ["{{ telegraf_vm_url }}"]
  database = "telegraf"
  retention_policy = ""
  write_consistency = "any"
  timeout = "5s"
  ## Tags để phân biệt site và role
  [outputs.influxdb.tagpass]
    host = ["*"]

# =============================================================================
# Global tags — gán cho tất cả metrics
# =============================================================================
[global_tags]
  host = "{{ inventory_hostname }}"
  site = "{{ site_name | default('default') }}"
  role = "{{ telegraf_node_role | default(group_names | first) }}"
  environment = "{{ environment_name | default('production') }}"
