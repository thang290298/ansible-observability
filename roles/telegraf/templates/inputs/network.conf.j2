# roles/telegraf/templates/inputs/network.conf.j2
# Metrics cho Network nodes — OVS, interface counters, Neutron agents
# Generated by Ansible — DO NOT EDIT MANUALLY

# =============================================================================
# Network interfaces — chi tiết hơn common
# =============================================================================
[[inputs.net]]
  ## Lấy tất cả interfaces (bao gồm bond, vlan, bridge)
  interfaces = []
  ignore_protocol_stats = false

# =============================================================================
# OVS — Open vSwitch metrics
# =============================================================================
[[inputs.exec]]
  commands = [
    "ovs-vsctl --format=json list bridge",
  ]
  timeout = "10s"
  data_format = "json"
  name_override = "ovs_bridge"
  [inputs.exec.tags]
    service = "ovs"

# =============================================================================
# OVS port stats via ovs-ofctl
# =============================================================================
[[inputs.exec]]
  commands = ["""ovs-vsctl list-br | xargs -I{} sh -c 'ovs-ofctl dump-ports {} | grep -v "OFPST" | awk -v bridge={} "{print bridge, $0}"'"""]
  timeout = "15s"
  data_format = "grok"
  grok_patterns = ["%{GREEDYDATA:raw}"]
  name_override = "ovs_port_stats"
  [inputs.exec.tags]
    service = "ovs"

# =============================================================================
# Neutron agent process checks
# =============================================================================
[[inputs.procstat]]
  pattern = "neutron-openvswitch-agent"
  [inputs.procstat.tags]
    service = "neutron-ovs-agent"

[[inputs.procstat]]
  pattern = "neutron-l3-agent"
  [inputs.procstat.tags]
    service = "neutron-l3-agent"

[[inputs.procstat]]
  pattern = "neutron-dhcp-agent"
  [inputs.procstat.tags]
    service = "neutron-dhcp-agent"

[[inputs.procstat]]
  pattern = "neutron-metadata-agent"
  [inputs.procstat.tags]
    service = "neutron-metadata-agent"

# =============================================================================
# Conntrack — connection tracking table
# =============================================================================
[[inputs.conntrack]]
  dirs = ["/proc/sys/net/netfilter", "/proc/sys/net/ipv4/netfilter"]
  files = ["ip_conntrack_count","ip_conntrack_max","nf_conntrack_count","nf_conntrack_max"]

# =============================================================================
# Bond interface status (nếu dùng bonding)
# =============================================================================
[[inputs.bond]]
  ## Tự detect bond interfaces
  bond_interfaces = []
