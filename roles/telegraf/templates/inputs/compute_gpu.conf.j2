# roles/telegraf/templates/inputs/compute_gpu.conf.j2
# Metrics cho Compute GPU nodes — NVIDIA GPU metrics via nvidia-smi
# Generated by Ansible — DO NOT EDIT MANUALLY

# =============================================================================
# NVIDIA GPU — via nvidia-smi
# =============================================================================
[[inputs.nvidia_smi]]
  ## Path tới nvidia-smi binary
  bin_path = "{{ telegraf_nvidia_bin }}"
  ## Timeout
  timeout = "5s"
  ## Thu thập thêm process metrics (GPU memory per process)
  use_sudo = false

# =============================================================================
# GPU process check
# =============================================================================
[[inputs.procstat]]
  pattern = "nvidia-persistenced"
  [inputs.procstat.tags]
    service = "nvidia-persistenced"

