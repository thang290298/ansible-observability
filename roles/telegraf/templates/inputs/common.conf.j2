# roles/telegraf/templates/inputs/common.conf.j2
# Metrics chung cho mọi server — CPU, RAM, Disk, Network, System
# Generated by Ansible — DO NOT EDIT MANUALLY

# =============================================================================
# CPU
# =============================================================================
[[inputs.cpu]]
  percpu = true
  totalcpu = true
  collect_cpu_time = false
  report_active = true
  core_tags = false

# =============================================================================
# Memory
# =============================================================================
[[inputs.mem]]

# =============================================================================
# Disk I/O
# =============================================================================
[[inputs.diskio]]
  ## Lọc chỉ disk thật, bỏ loop/tmpfs
  device_exclude = ["loop*", "ram*", "fd*"]

# =============================================================================
# Disk Usage
# =============================================================================
[[inputs.disk]]
  ignore_fs = ["tmpfs", "devtmpfs", "devfs", "iso9660", "overlay", "aufs", "squashfs"]

# =============================================================================
# Network interfaces
# =============================================================================
[[inputs.net]]
  ignore_protocol_stats = true

# =============================================================================
# System load & uptime
# =============================================================================
[[inputs.system]]

# =============================================================================
# Processes
# =============================================================================
[[inputs.processes]]

# =============================================================================
# Swap
# =============================================================================
[[inputs.swap]]

# =============================================================================
# Kernel
# =============================================================================
[[inputs.kernel]]

# =============================================================================
# Netstat
# =============================================================================
[[inputs.netstat]]

# =============================================================================
# Systemd units health check
# =============================================================================
[[inputs.systemd_units]]
  unit_filter = ["telegraf.service", "ssh.service", "cron.service"]
  timeout = "5s"

# =============================================================================
# Internal telegraf metrics
# =============================================================================
[[inputs.internal]]
  collect_memstats = false
