# roles/telegraf/templates/inputs/compute.conf.j2
# Metrics cho Compute nodes — Libvirt VMs, Nova, CPU performance
# Generated by Ansible — DO NOT EDIT MANUALLY

# =============================================================================
# Libvirt — VM metrics (CPU, RAM, disk, network per VM)
# =============================================================================
[[inputs.libvirt]]
  uri_source = "qemu:///system"
  ## Metrics cần thu thập
  gather_vcpu_stats = true
  gather_disk_stats = true
  gather_net_stats = true
  gather_block_stats = true
  gather_perf_events = true
  ## Performance events
  perf_events = [
    "cmt", "mbmt", "mbml",
    "cpu_cycles", "instructions",
    "cache_references", "cache_misses",
    "branch_instructions", "branch_misses",
  ]

# =============================================================================
# CPU perf — Per-core detailed stats
# =============================================================================
[[inputs.cpu]]
  percpu = true
  totalcpu = true
  collect_cpu_time = true
  report_active = true
  [inputs.cpu.tags]
    node_type = "compute"

# =============================================================================
# Nova process check
# =============================================================================
[[inputs.procstat]]
  pattern = "nova-compute"
  [inputs.procstat.tags]
    service = "nova-compute"

# =============================================================================
# HTTP check — Nova metadata API
# =============================================================================
[[inputs.http_response]]
  urls = ["http://localhost:8775/"]
  response_timeout = "5s"
  method = "GET"
  [inputs.http_response.tags]
    service = "nova-metadata"
