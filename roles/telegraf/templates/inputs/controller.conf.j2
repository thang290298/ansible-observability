# roles/telegraf/templates/inputs/controller.conf.j2
# Metrics cho Controller nodes — OpenStack APIs, RabbitMQ, MySQL/MariaDB
# Generated by Ansible — DO NOT EDIT MANUALLY

# =============================================================================
# RabbitMQ — Queue metrics, connections, message rates
# =============================================================================
[[inputs.rabbitmq]]
  url = "{{ telegraf_rabbitmq_url }}"
  username = "{{ telegraf_rabbitmq_username }}"
  password = "{{ telegraf_rabbitmq_password }}"
  ## Giới hạn queue lấy metrics (tránh quá nhiều queues)
  queue_name_include = []
  queue_name_exclude = ["aliveness-test"]
  timeout = "5s"
  [inputs.rabbitmq.tags]
    service = "rabbitmq"

# =============================================================================
# MySQL / MariaDB — DB performance metrics
# =============================================================================
[[inputs.mysql]]
  servers = ["{{ telegraf_mysql_dsn }}"]
  metric_version = 2
  gather_slave_status = true
  gather_binary_logs = false
  gather_table_io_waits = false
  gather_table_lock_waits = false
  gather_index_io_waits = false
  gather_event_waits = false
  gather_file_events_stats = false
  gather_perf_events_statements = false
  perf_events_statements_digest_text_limit = 120
  perf_events_statements_limit = 250
  perf_events_statements_time_limit = 86400
  [inputs.mysql.tags]
    service = "mariadb"

# =============================================================================
# OpenStack API health checks — HTTP response time
# =============================================================================
[[inputs.http_response]]
  urls = [
    "http://localhost:5000/v3",         # Keystone
    "http://localhost:8774/",           # Nova API
    "http://localhost:9696/",           # Neutron
    "http://localhost:8776/v3/",        # Cinder
    "http://localhost:9292/",           # Glance
    "http://localhost:8004/",           # Heat
  ]
  response_timeout = "10s"
  method = "GET"
  follow_redirects = true
  [inputs.http_response.tags]
    service = "openstack-api"

# =============================================================================
# Controller process checks
# =============================================================================
[[inputs.procstat]]
  pattern = "nova-api"
  [inputs.procstat.tags]
    service = "nova-api"

[[inputs.procstat]]
  pattern = "neutron-server"
  [inputs.procstat.tags]
    service = "neutron-server"

[[inputs.procstat]]
  pattern = "keystone"
  [inputs.procstat.tags]
    service = "keystone"

# =============================================================================
# Memcached (nếu controller dùng memcached cho Keystone)
# =============================================================================
[[inputs.memcached]]
  servers = ["localhost:11211"]
  [inputs.memcached.tags]
    service = "memcached"
