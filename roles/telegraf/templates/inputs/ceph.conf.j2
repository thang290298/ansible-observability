# roles/telegraf/templates/inputs/ceph.conf.j2
# Metrics cho Ceph nodes — MON, OSD, Pool, RGW
# Generated by Ansible — DO NOT EDIT MANUALLY

# =============================================================================
# Ceph — Monitor, OSD, Pool metrics qua ceph socket
# =============================================================================
[[inputs.ceph]]
  ## Interval riêng cho ceph (nặng hơn)
  interval = "30s"

  ## Ceph socket dir
  ceph_binary = "/usr/bin/ceph"
  socket_dir = "{{ telegraf_ceph_socket_dir }}"
  mon_prefix = "{{ telegraf_ceph_socket_prefix }}mon"
  osd_prefix = "{{ telegraf_ceph_socket_prefix }}osd"
  mds_prefix = "{{ telegraf_ceph_socket_prefix }}mds"
  rgw_prefix = "{{ telegraf_ceph_socket_prefix }}client.rgw"

  gather_admin_socket_stats = true
  gather_cluster_stats = false  # cluster stats dùng ceph_osd_df thay thế

  [inputs.ceph.tags]
    service = "ceph"

# =============================================================================
# Ceph cluster status qua exec — ceph -s
# =============================================================================
[[inputs.exec]]
  interval = "30s"
  commands = [
    "ceph -s --format json",
  ]
  timeout = "30s"
  data_format = "json"
  name_override = "ceph_status"
  tag_keys = ["fsid"]
  [inputs.exec.tags]
    service = "ceph"

# =============================================================================
# Ceph OSD usage — ceph osd df
# =============================================================================
[[inputs.exec]]
  interval = "60s"
  commands = [
    "ceph osd df --format json",
  ]
  timeout = "30s"
  data_format = "json"
  name_override = "ceph_osd_df"
  [inputs.exec.tags]
    service = "ceph"

# =============================================================================
# Ceph pool stats — ceph df detail
# =============================================================================
[[inputs.exec]]
  interval = "60s"
  commands = [
    "ceph df detail --format json",
  ]
  timeout = "30s"
  data_format = "json"
  name_override = "ceph_df"
  [inputs.exec.tags]
    service = "ceph"

# =============================================================================
# Ceph process checks
# =============================================================================
[[inputs.procstat]]
  pattern = "ceph-osd"
  [inputs.procstat.tags]
    service = "ceph-osd"

[[inputs.procstat]]
  pattern = "ceph-mon"
  [inputs.procstat.tags]
    service = "ceph-mon"

# =============================================================================
# Disk I/O — chi tiết hơn cho OSD disks
# =============================================================================
[[inputs.diskio]]
  ## Chỉ lấy disk thật (bỏ loop, ram)
  device_exclude = ["loop*", "ram*"]
  extended_stats = true
  [inputs.diskio.tags]
    node_type = "ceph-storage"
