# vminsert — nhận metrics và ghi vào vmstorage cluster
# Group: monitoring_query ({{ groups['monitoring_query'] | length }} nodes)
# storageNode: {{ vmstorage_nodes | join(', ') }}

services:
  vminsert:
    image: victoriametrics/vminsert:{{ victoriametrics_version }}
    container_name: vminsert
    restart: unless-stopped
    command:
      - "--storageNode={{ vmstorage_nodes | join(',') }}"
      - "--replicationFactor={{ vm_replication_factor }}"
      - "--httpListenAddr=:{{ vminsert_port }}"
      - "--loggerLevel=INFO"
      - "--maxConcurrentInserts=32"
    ports:
      - "{{ vminsert_internal_port | default(vminsert_port) }}:{{ vminsert_port }}"
    mem_limit: "{{ vminsert_mem_limit | default('1g') }}"
    cpus: "{{ vminsert_cpu_limit | default('1.0') }}"
    labels:
      monitoring: "true"
      component: "vminsert"
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "3"
