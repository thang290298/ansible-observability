version: "3.8"

# =============================================================================
# Gitea — Self-hosted Git server
# =============================================================================

services:
  gitea:
    image: gitea/gitea:{{ gitea_version }}
    container_name: gitea
    restart: unless-stopped
    environment:
      USER_UID: 1000
      USER_GID: 1000
      GITEA__database__DB_TYPE: postgres
      GITEA__database__HOST: "{{ hostvars[groups['monitoring_db'][0]]['ansible_host'] }}:{{ postgres_port }}"
      GITEA__database__NAME: gitea
      GITEA__database__USER: gitea
      GITEA__database__PASSWD: "{{ gitea_db_password }}"
      GITEA__server__HTTP_PORT: "{{ gitea_port }}"
      GITEA__server__SSH_PORT: "{{ gitea_ssh_port }}"
      GITEA__server__DOMAIN: "{{ ansible_host }}"
      GITEA__server__ROOT_URL: "http://{{ ansible_host }}:{{ gitea_port }}/"
      GITEA__security__SECRET_KEY: "{{ gitea_secret_key }}"
      GITEA__security__INSTALL_LOCK: "true"
      GITEA_ADMIN_USER: "{{ gitea_admin_user | default('incosys') }}"
      GITEA_ADMIN_PASSWORD: "{{ gitea_admin_password }}"
      GITEA_ADMIN_EMAIL: "{{ gitea_admin_email | default('admin@monitoring.local') }}"
    volumes:
      - {{ gitea_data_path }}/git:/data
      - {{ gitea_data_path }}/config:/etc/gitea
      - /etc/timezone:/etc/timezone:ro
      - /etc/localtime:/etc/localtime:ro
    ports:
      - "{{ gitea_port }}:{{ gitea_port }}"
      - "{{ gitea_ssh_port }}:22"
    labels:
      monitoring: "true"
      component: "gitea"
