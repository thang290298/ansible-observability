#!/bin/bash
# Loki Config Backup Script
# Backup Loki configuration files

set -e

BACKUP_DIR="{{ backup_base_dir }}/loki"
LOKI_CONFIG_DIR="{{ monitoring_base_dir }}/loki"
RETENTION_DAYS="{{ backup_retention_days }}"

mkdir -p "$BACKUP_DIR"

echo "[$(date)] Starting Loki config backup..."

# Backup config
BACKUP_FILE="$BACKUP_DIR/loki-config-$(date +%Y%m%d-%H%M%S).tar.gz"

tar -czf "$BACKUP_FILE" \
    -C "{{ monitoring_base_dir }}" loki/ \
    2>/dev/null

if [ -f "$BACKUP_FILE" ]; then
    SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
    echo "[$(date)] Config backup completed: $BACKUP_FILE (Size: $SIZE)"
    
    # Optional: Upload to S3
    {% if backup_to_s3 %}
    aws s3 cp "$BACKUP_FILE" "s3://{{ backup_s3_bucket }}/{{ backup_s3_prefix }}/loki/"
    {% endif %}
else
    echo "[$(date)] ERROR: Config backup failed"
    exit 1
fi

# Cleanup old backups
find "$BACKUP_DIR" -name "loki-config-*.tar.gz" -mtime +"$RETENTION_DAYS" -delete

echo "[$(date)] Loki config backup completed"
