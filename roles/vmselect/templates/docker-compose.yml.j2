# vmselect — xử lý query, đọc từ vmstorage cluster
# Group: monitoring_query ({{ groups['monitoring_query'] | length }} nodes)
# storageNode: {{ vmstorage_select_nodes | join(', ') }}

services:
  vmselect:
    image: victoriametrics/vmselect:{{ victoriametrics_version }}
    container_name: vmselect
    restart: unless-stopped
    command:
      - "--storageNode={{ vmstorage_select_nodes | join(',') }}"
      - "--dedup.minScrapeInterval={{ vmagent_scrape_interval }}"
      - "--httpListenAddr=:{{ vmselect_port }}"
      - "--loggerLevel=INFO"
      - "--search.maxConcurrentRequests=16"
      - "--search.maxQueryDuration=60s"
      - "--cacheDataPath=/vmselect-cache"
    volumes:
      - vmselect_cache:/vmselect-cache
    ports:
      - "{{ vmselect_internal_port | default(vmselect_port) }}:{{ vmselect_port }}"
    mem_limit: "{{ vmselect_mem_limit | default('2g') }}"
    cpus: "{{ vmselect_cpu_limit | default('1.5') }}"
    labels:
      monitoring: "true"
      component: "vmselect"
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "3"

volumes:
  vmselect_cache:
    driver: local
