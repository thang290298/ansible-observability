
# =============================================================================
# Grafana — Dashboard & Visualization
# PostgreSQL backend cho HA (shared state giữa các instances)
# =============================================================================

services:
  grafana:
    image: grafana/grafana:{{ grafana_version }}
    container_name: grafana
    restart: unless-stopped
    environment:
      GF_SERVER_HTTP_PORT: "3000"
      GF_SERVER_ROOT_URL: "http://{{ vip_address }}:{{ grafana_port }}"
      GF_DATABASE_TYPE: postgres
      GF_DATABASE_HOST: "{{ grafana_db_host }}:{{ grafana_db_port }}"
      GF_DATABASE_NAME: "{{ grafana_db_name }}"
      GF_DATABASE_USER: "{{ grafana_db_user }}"
      GF_DATABASE_PASSWORD: "{{ grafana_db_password }}"
      GF_DATABASE_SSL_MODE: disable
      GF_SECURITY_ADMIN_USER: "{{ grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ grafana_admin_password }}"
      GF_SECURITY_ALLOW_EMBEDDING: "true"
      GF_AUTH_ANONYMOUS_ENABLED: "false"
      GF_USERS_ALLOW_SIGN_UP: "false"
      GF_ANALYTICS_REPORTING_ENABLED: "false"
      GF_ANALYTICS_CHECK_FOR_UPDATES: "false"
      GF_LOG_LEVEL: info
    volumes:
      - {{ grafana_data_path }}:/var/lib/grafana
      - ./provisioning:/etc/grafana/provisioning:ro
    ports:
      - "{{ grafana_port }}:3000"
    labels:
      monitoring: "true"
      component: "grafana"
