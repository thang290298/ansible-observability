apiVersion: 1

# Grafana dashboard provisioning configuration
# Automatically discovers dashboards in dashboards-enabled/ directory

providers:
  - name: 'Default'
    orgId: 1
    folder: 'Provisioned'
    type: file
    disableDeletion: false
    updateIntervalSeconds: 10
    allowUiUpdates: true
    options:
      path: /etc/grafana/provisioning/dashboards-enabled
