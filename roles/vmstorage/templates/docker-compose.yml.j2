# vmstorage — chỉ lưu trữ, không xử lý query/insert
# Group: monitoring_storage ({{ groups['monitoring_storage'] | length }} nodes)

services:
  vmstorage:
    image: victoriametrics/vmstorage:{{ victoriametrics_version }}
    container_name: vmstorage
    restart: unless-stopped
    command:
      - "--storageDataPath=/vmstorage-data"
      - "--retentionPeriod={{ vm_retention_period }}"
      - "--httpListenAddr=:{{ vmstorage_port }}"
      - "--vminsertAddr=:{{ vmstorage_vminsert_port }}"
      - "--vmselectAddr=:{{ vmstorage_vmselect_port }}"
      - "--loggerLevel=INFO"
      - "--memory.allowedPercent=80"
      # Dedup data từ 2 vmagent active-active — interval khớp với scrape_interval
      - "--dedup.minScrapeInterval={{ vmagent_scrape_interval }}"
    volumes:
      - {{ vm_storage_data_path }}:/vmstorage-data
    ports:
      - "{{ vmstorage_port }}:{{ vmstorage_port }}"
      - "{{ vmstorage_vminsert_port }}:{{ vmstorage_vminsert_port }}"
      - "{{ vmstorage_vmselect_port }}:{{ vmstorage_vmselect_port }}"
    mem_limit: "{{ vmstorage_mem_limit | default('4g') }}"
    cpus: "{{ vmstorage_cpu_limit | default('2.0') }}"
    labels:
      monitoring: "true"
      component: "vmstorage"
    logging:
      driver: "json-file"
      options:
        max-size: "100m"
        max-file: "3"
