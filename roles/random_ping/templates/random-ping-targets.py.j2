#!/usr/bin/env python3
# Auto-generated by Ansible — DO NOT EDIT MANUALLY
# random-ping-targets.py — Rotate random ping pairs every {{ random_ping_rotate_interval }}s

import random
import yaml
import time
import logging
import os
from datetime import datetime

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [random-ping] %(message)s'
)

CONFIG_FILE = "/opt/monitoring/random-ping/nodes.yml"
OUTPUT_FILE = "/etc/blackbox/random-ping-targets.yml"
PAIRS_PER_ROUND = {{ random_ping_pairs_per_round | default(10) }}
ROTATE_INTERVAL = {{ random_ping_rotate_interval | default(120) }}

def load_nodes():
    with open(CONFIG_FILE) as f:
        return yaml.safe_load(f)['nodes']

def generate_random_pairs(nodes, count):
    pairs = []
    used = set()
    attempts = 0
    while len(pairs) < count and attempts < count * 20:
        src, dst = random.sample(nodes, 2)
        key = (src['name'], dst['name'])
        if key not in used:
            pairs.append((src, dst))
            used.add(key)
        attempts += 1
    return pairs

def write_targets(pairs):
    targets = []
    round_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    for src, dst in pairs:
        targets.append({
            "targets": [dst['ip']],
            "labels": {
                "src_node": src['name'],
                "src_ip":   src['ip'],
                "dst_node": dst['name'],
                "dst_ip":   dst['ip'],
                "job":      "random-ping",
                "round_at": round_time,
                "site":     dst.get('site', 'default')
            }
        })
    os.makedirs(os.path.dirname(OUTPUT_FILE), exist_ok=True)
    with open(OUTPUT_FILE, 'w') as f:
        yaml.dump(targets, f, default_flow_style=False, allow_unicode=True)
    logging.info(f"Round {round_time}: {len(pairs)} pairs generated")
    for src, dst in pairs:
        logging.info(f"  {src['name']} ({src['ip']}) → {dst['name']} ({dst['ip']})")

if __name__ == "__main__":
    logging.info("Random ping target rotator started")
    while True:
        try:
            nodes = load_nodes()
            pairs = generate_random_pairs(nodes, PAIRS_PER_ROUND)
            write_targets(pairs)
        except Exception as e:
            logging.error(f"Error: {e}")
        time.sleep(ROTATE_INTERVAL)
